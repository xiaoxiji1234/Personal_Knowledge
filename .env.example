# Local data paths
KNOWLEDGE_AGENT_DATA_DIR=data
KNOWLEDGE_AGENT_UPLOAD_DIR=data/uploads
KNOWLEDGE_AGENT_INDEX_PATH=data/index/store.json

# Retrieval
CHUNK_SIZE=900
CHUNK_OVERLAP=120
TOP_K=5
CONFIDENCE_THRESHOLD=0.72

# LLM
# local: use deterministic local summarizer
# openai: use OpenAI-compatible /chat/completions API
# http: use the legacy custom JSON gateway at LLM_ENDPOINT
LLM_PROVIDER=local
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=20

# Optional custom LLM gateway for LLM_PROVIDER=http
LLM_ENDPOINT=

# Optional web search gateway
SEARCH_ENDPOINT=
SEARCH_API_KEY=
SEARCH_TIMEOUT_SECONDS=8
